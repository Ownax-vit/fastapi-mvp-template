# Application Settings
APP_APP_NAME=FastAPI Sample Template
APP_APP_VERSION=1.0.0
APP_DEBUG=false

# Database Settings
# SQLite (default)
APP_DB_URL=sqlite+aiosqlite:///./sqlite/app.db
# PostgreSQL (alternative)
# APP_DB_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
APP_DB_ECHO=false

# Logging Settings
APP_LOG_LEVEL=INFO
APP_LOG_FILE=./logs/app.log

# CORS Settings (comma-separated origins, or * for all)
APP_CORS_ORIGINS=*

# Server Settings
APP_HOST=0.0.0.0
APP_PORT=8000
